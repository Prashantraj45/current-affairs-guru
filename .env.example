# API Keys (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-v7-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MongoDB (get from https://mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/upsc-ai?retryWrites=true&w=majority

# Admin Control (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SECRET=your-random-64-character-secret-key-here-change-in-production

# Server Configuration
PORT=3000
NODE_ENV=development

# Scheduler Configuration
SCHEDULER_ENABLED=true
JOB_TIME=05:00

# Security (optional)
CORS_ORIGIN=http://localhost:3001
LOG_LEVEL=info
